APP_NAME=splice-playground
APP_VERSION=0.1.0
API_PREFIX=/api

# IMPORTANT: when the GPU worker is live, set this to the real Vercel origin.
CORS_ORIGINS=https://your-real-project.vercel.app,http://localhost:8501

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_KEY

STEP1_IMAGE_BUCKET=STEP1_image
STEP4_STRUCTURE_BUCKET=structure-assets
SIGNED_URL_EXPIRES_IN=3600

# CPU API server: enable the queueing endpoints once the GPU worker exists.
STEP4_ENABLE_STRUCTURE_JOBS=true
SPLICEAI_DEVICE=cpu

HTTP_USER_AGENT=splice-playground-api/0.1
EXTERNAL_API_TIMEOUT_SECONDS=30
SUPABASE_RETRY_ATTEMPTS=3
SUPABASE_RETRY_BACKOFF_SECONDS=0.75
STEP4_JOB_POLL_SECONDS=15
STEP4_ARTIFACT_POLICY=minimal
STEP4_MAX_STATE_JOB_SUMMARY=3
