APP_NAME=splice-playground
APP_VERSION=0.1.0
API_PREFIX=/api

# Replace with your public Vercel frontend URL(s) and local dev GUI if needed
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:8501

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_KEY

STEP1_IMAGE_BUCKET=STEP1_image
STEP4_STRUCTURE_BUCKET=structure-assets
SIGNED_URL_EXPIRES_IN=3600

STEP4_ENABLE_STRUCTURE_JOBS=false

# Normal baseline structures from Supabase Storage are still returned even when
# STEP4_ENABLE_STRUCTURE_JOBS=false. Turn this on later only on the GPU-backed
# deployment that also runs scripts/run_step4_jobs.py.

SPLICEAI_MODEL_PATH=app/ai_models/spliceai_window=10000.pt
SPLICEAI_MODEL_VERSION=spliceai10k_custom_v1
SPLICEAI_DEVICE=cpu

HTTP_USER_AGENT=splice-playground-backend/0.1
EXTERNAL_API_TIMEOUT_SECONDS=30

NCBI_TOOL=splice-playground
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# Not used on the CPU API server, but harmless if present
COLABFOLD_BATCH_CMD=colabfold_batch
COLABFOLD_EXTRA_ARGS=
STEP4_JOB_WORKDIR=/tmp/step4_jobs
STEP4_JOB_TIMEOUT_SECONDS=21600
STEP4_ALIGNMENT_BIN=
