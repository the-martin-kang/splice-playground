APP_NAME=splice-playground-step4-worker
APP_VERSION=0.1.0
API_PREFIX=/api
CORS_ORIGINS=

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_ANON_KEY

STEP4_STRUCTURE_BUCKET=structure-assets
SIGNED_URL_EXPIRES_IN=3600

HTTP_USER_AGENT=splice-playground-step4-worker/0.1
EXTERNAL_API_TIMEOUT_SECONDS=30

NCBI_TOOL=splice-playground
NCBI_EMAIL=you@example.com
NCBI_API_KEY=

# Worker-only host: this flag does not affect queue polling, but keeping it true
# makes local smoke tests and ad-hoc API runs consistent with the GPU-ready mode.
STEP4_ENABLE_STRUCTURE_JOBS=true

COLABFOLD_BATCH_CMD=/usr/local/bin/colabfold_batch_worker
COLABFOLD_EXTRA_ARGS=
STEP4_JOB_WORKDIR=/data/step4_jobs
STEP4_JOB_TIMEOUT_SECONDS=21600
STEP4_ALIGNMENT_BIN=
SUPABASE_RETRY_ATTEMPTS=3
SUPABASE_RETRY_BACKOFF_SECONDS=0.75
STEP4_JOB_POLL_SECONDS=15
STEP4_ARTIFACT_POLICY=minimal
STEP4_MAX_STATE_JOB_SUMMARY=3
